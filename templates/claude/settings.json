{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-workflow/dist/hooks/session-start.js",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-workflow/dist/hooks/session-end.js",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node node_modules/dev-workflow/dist/lib/statusline.js"
  }
}
