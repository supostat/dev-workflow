{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-vault/dist/hooks/session-start.js",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-vault/dist/hooks/session-end.js",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-vault/dist/hooks/pre-compact.js",
            "timeout": 8000
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/dev-vault/dist/hooks/pre-compact.js",
            "timeout": 8000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node node_modules/dev-vault/dist/lib/statusline.js"
  }
}
