{
  "name": "@engramm/dev-workflow",
  "version": "0.1.3",
  "description": "Development workflow engine with agents and vault for Claude Code",
  "type": "module",
  "bin": {
    "dev-workflow": "./dist/cli/index.js",
    "dev-vault": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "claude-code",
    "developer-tools",
    "workflow",
    "agents",
    "mcp",
    "vault",
    "obsidian"
  ],
  "author": "Igor Pugachev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/supostat/dev-workflow.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.22.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
